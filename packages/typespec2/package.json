{
  "name": "@specloom/typespec2",
  "version": "0.0.0",
  "description": "TypeSpec v2 decorators and emitter for specloom",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "lib"
  ],
  "typespec": "./lib/main.tsp",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "../../node_modules/.bin/vitest run"
  },
  "keywords": [
    "typespec",
    "specloom",
    "admin",
    "compiled"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@typespec/compiler": ">=0.60.0"
  },
  "devDependencies": {
    "@typespec/compiler": "^0.64.0",
    "typescript": "^5.7.0"
  }
}
